{
    "workbench.colorCustomizations": {
        "editorRuler.foreground": "#ffffff8b",
        "tab.activeBackground": "#00305f",
        "tab.activeForeground": "#FFFFFF",
        "tab.unfocusedActiveBorder": "#FFFFFF",
        "tab.activeBorderTop": "#FFFFFF",
        "statusBar.foreground": "#FFFFFF",
        "activityBarBadge.background": "#86cbff",
        "activityBar.activeBorder": "#FFFFFF",
        "panelTitle.activeBorder": "#FFFFFF",
        "panelTitle.activeForeground": "#86cbff",
        "panelTitle.inactiveForeground": "#ffffff",
        "terminal.tab.activeBorder": "#FFFFFF",
        "focusBorder": "#FFFFFF",
        "panel.background": "#1f2428",
        "panelSection.background": "#1f2428",
        "panelSectionHeader.background": "#1f2428",
        "panelStickyScroll.background": "#1f2428",
        "editorGroupHeader.tabsBackground": "#1f2428",
        "terminal.background": "#1f2428",
        "terminal.foreground": "#ffffff",
        "terminal.ansiBlack": "#000000",
        "terminal.ansiRed": "#73ceff",
        "terminal.ansiGreen": "#73ceff",
        "terminal.ansiYellow": "#ffc100",
        "terminal.ansiBlue": "#bf9cf3",
        "terminal.ansiMagenta": "#ff77ff",
        "terminal.ansiCyan": "#ff6d67",
        "terminal.ansiWhite": "#bbbbbb",
        "terminal.ansiBrightBlack": "#555555",
        "terminal.ansiBrightRed": "#73ceff",
        "terminal.ansiBrightGreen": "#73ceff",
        "terminal.ansiBrightYellow": "#ffc100",
        "terminal.ansiBrightBlue": "#bf9cf3",
        "terminal.ansiBrightMagenta": "#ff55ff",
        "terminal.ansiBrightCyan": "#ff6d67",
        "terminal.ansiBrightWhite": "#ffffff",
        "terminalCursor.foreground": "#73ceff"
    },
    "explorer.openEditors.dynamicHeight": false, 
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": "variable",
                "settings": {
                    "foreground": "#2BD058"
                }
            },
            {
                "scope": "function",
                "settings": {
                    "foreground": "#2BD058"
                }
            }
        ]
    },
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.external.osxExec": "iTerm.app",
    "terminal.integrated.macOptionIsMeta": true,
    "workbench.startupEditor": "none",
    "security.workspace.trust.untrustedFiles": "open",
    "git.autofetch": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "terminal.integrated.enableMultiLinePasteWarning": false,
    "git.enableSmartCommit": true,
    "githubPullRequests.pullBranch": "never",
    "[python]": {
        "diffEditor.ignoreTrimWhitespace": true
    },
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
    },
    "security.promptForLocalFileProtocolHandling": false,
    "go.toolsManagement.autoUpdate": true,
    "cursor-retrieval.canAttemptGithubLogin": false,
    "workbench.colorTheme": "GitHub Dark",
    "githubPullRequests.fileListLayout": "flat",
    "testing.coverageToolbarEnabled": true,
    "cursor.cpp.disabledLanguages": [
        "plaintext"
    ],
    "workbench.editor.enablePreview": true,
    "workbench.settings.applyToAllProfiles": [
        
    ],
    "diffEditor.renderSideBySide": false,
    "editor.dropIntoEditor.preferences": [],
    "[yaml]": {
        "diffEditor.ignoreTrimWhitespace": true
    },
    "githubPullRequests.createOnPublishBranch": "never",
    "editor.insertSpaces": false,
    "window.zoomLevel": 0.1,
    "python.createEnvironment.trigger": "off"
}