## GitHub Dark — JSON / JSONC / JSON5

syntax "json-gh" "\.json[c5]?$"
comment "//"

# Numbers
color #8cf "-?\<([0-9]+(\.[0-9]+)?)([eE][-+]?[0-9]+)?\>"

# Literals
color #8cf "\<(true|false|null)\>"

# All strings (values default)
color #adf ""([^"\]|\\.)*""

# Keys override string color ("key":) — purple identifier
color #dbf ""([^"\]|\\.)*"[[:blank:]]*:"

# Comments (JSONC / JSON5)
color #888 "(^|[[:blank:]])//.*"
color #888 start="/\*" end="\*/"
