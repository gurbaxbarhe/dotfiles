## GitHub Dark — JSON / JSONC

syntax "json-gh" "\.json[c5]?$"
comment "//"

# Numbers
color lagoon "-?\<([0-9]+(\.[0-9]+)?)([eE][-+]?[0-9]+)?\>"

# Literals
color lagoon "\<(true|false|null)\>"

# All strings (values)
color sky ""([^"\]|\\.)*""

# Keys override string color ("key":)
color lagoon ""([^"\]|\\.)*"[[:blank:]]*:"

# Comments (JSONC / JSON5)
color grey "(^|[[:blank:]])//.*"
color grey start="/\*" end="\*/"
