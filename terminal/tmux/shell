#!/bin/bash

# Unset TMUX to allow proper nesting
unset TMUX

# Generate unique session name if not provided
SESSION=${SESSION:-"mysession$(date +%s)"}

# Start fresh session detached with specific size
/opt/homebrew/bin/tmux new-session -d -s $SESSION -x "$(tput cols)" -y "$(tput lines)"
sleep 0.2

# Create the split with exact lines for bottom pane (69 rows)
/opt/homebrew/bin/tmux split-window -v -l 45 -c '#{pane_current_path}'

# Name the panes
/opt/homebrew/bin/tmux select-pane -t 0
/opt/homebrew/bin/tmux select-pane -T "Git"
/opt/homebrew/bin/tmux select-pane -t 1
/opt/homebrew/bin/tmux select-pane -T "Work"

# Set up continuous Git branch monitoring in top pane
/opt/homebrew/bin/tmux send-keys -t ${SESSION}:0.0 "TERM=xterm-256color; while true; do 
    clear
    CURRENT_PATH=\$(/opt/homebrew/bin/tmux display-message -p -t ${SESSION}:0.1 '#{pane_current_path}')
    
    if [ -n \"\$CURRENT_PATH\" ] && [ -d \"\$CURRENT_PATH\" ]; then
        cd \"\$CURRENT_PATH\"
        echo \"📂 \$CURRENT_PATH\"
        echo \"\"
        
        if git rev-parse --git-dir > /dev/null 2>&1; then
            git branch --sort=-committerdate | while read branch; do
                if [[ \$branch == \"*\"* ]]; then
                    # Current branch (remove the * and leading space)
                    branch_name=\${branch#\"* \"}
                    printf \"* \033[38;2;137;204;253m%s\033[0m\n\" \"\$branch_name\"
                else
                    # Other branches (keep the leading spaces)
                    printf \"%s\n\" \"\$branch\"
                fi
            done
        else
            echo \"⚠️ Not a Git directory\"
        fi
    else
        echo \"❌ Waiting for valid directory...\"
    fi
    sleep 3
done" C-m

# Move tmux status bar to top
/opt/homebrew/bin/tmux set-option -t $SESSION status-position top

# Configure status-right format to show full date
/opt/homebrew/bin/tmux set-option -t $SESSION status-right " \"#{pane_title}\" %y-%m-%d %H:%M "

# Focus on bottom pane (Work)
/opt/homebrew/bin/tmux select-pane -t 1

# Attach
/opt/homebrew/bin/tmux attach-session -t $SESSION